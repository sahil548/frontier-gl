// DI-01: All money/financial fields use Decimal(19,4) — @db.Decimal(19, 4)
// DI-02: All financial tables include entityId FK for entity-scoped data isolation

generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model User {
  id           String         @id @default(cuid())
  clerkId      String         @unique
  email        String         @unique
  name         String?
  createdAt    DateTime       @default(now())
  updatedAt    DateTime       @updatedAt
  entities     Entity[]
  entityAccess EntityAccess[]
}

model Entity {
  id             String         @id @default(cuid())
  name           String
  type           EntityType
  typeOther      String?
  fiscalYearEnd  String
  coaTemplate    CoaTemplate    @default(BLANK)
  isActive       Boolean        @default(true)
  createdById    String
  createdAt      DateTime       @default(now())
  updatedAt      DateTime       @updatedAt
  createdBy      User           @relation(fields: [createdById], references: [id])
  accounts       Account[]
  journalEntries JournalEntry[]
  periodCloses   PeriodClose[]
  templates      JournalEntryTemplate[]
  subledgerItems SubledgerItem[]
  access         EntityAccess[]

  @@index([createdById])
  @@index([isActive])
}

model Account {
  id          String             @id @default(cuid())
  entityId    String
  number      String
  name        String
  type        AccountType
  description String?
  parentId    String?
  isActive    Boolean            @default(true)
  createdAt   DateTime           @default(now())
  updatedAt   DateTime           @updatedAt
  balance     AccountBalance?
  entity      Entity             @relation(fields: [entityId], references: [id])
  parent      Account?           @relation("AccountHierarchy", fields: [parentId], references: [id])
  children    Account[]          @relation("AccountHierarchy")
  lineItems      JournalEntryLine[]
  templateLines  JournalEntryTemplateLine[]
  subledgerItems SubledgerItem[]

  @@unique([entityId, number])
  @@index([entityId, isActive])
  @@index([entityId, type])
  @@map("accounts")
}

model AccountBalance {
  id          String   @id @default(cuid())
  accountId   String   @unique
  debitTotal  Decimal  @default(0) @db.Decimal(19, 4)
  creditTotal Decimal  @default(0) @db.Decimal(19, 4)
  balance     Decimal  @default(0) @db.Decimal(19, 4)
  updatedAt   DateTime @updatedAt
  account     Account  @relation(fields: [accountId], references: [id])

  @@map("account_balances")
}

model JournalEntry {
  id           String              @id @default(cuid())
  entityId     String
  entryNumber  String
  date         DateTime            @db.Date
  description  String
  status       JournalEntryStatus  @default(DRAFT)
  createdBy    String
  approvedBy   String?
  postedBy     String?
  createdAt    DateTime            @default(now())
  approvedAt   DateTime?
  postedAt     DateTime?
  updatedAt    DateTime            @updatedAt
  reversalOfId String?             @unique
  entity       Entity              @relation(fields: [entityId], references: [id])
  reversalOf   JournalEntry?       @relation("Reversal", fields: [reversalOfId], references: [id])
  reversedBy   JournalEntry?       @relation("Reversal")
  templateId   String?
  template     JournalEntryTemplate? @relation(fields: [templateId], references: [id])
  auditEntries JournalEntryAudit[]
  lineItems    JournalEntryLine[]
  attachments  Attachment[]

  @@unique([entityId, entryNumber])
  @@index([entityId, status])
  @@index([entityId, date])
  @@map("journal_entries")
}

model JournalEntryLine {
  id             String       @id @default(cuid())
  journalEntryId String
  accountId      String
  debit          Decimal      @default(0) @db.Decimal(19, 4)
  credit         Decimal      @default(0) @db.Decimal(19, 4)
  memo           String?
  sortOrder      Int          @default(0)
  account        Account      @relation(fields: [accountId], references: [id])
  journalEntry   JournalEntry @relation(fields: [journalEntryId], references: [id], onDelete: Cascade)
  reconciliationLines BankReconciliationLine[]

  @@index([journalEntryId])
  @@index([accountId])
  @@map("journal_entry_lines")
}

model JournalEntryAudit {
  id             String       @id @default(cuid())
  journalEntryId String
  action         String
  userId         String
  changes        Json?
  createdAt      DateTime     @default(now())
  journalEntry   JournalEntry @relation(fields: [journalEntryId], references: [id])

  @@index([journalEntryId])
  @@map("journal_entry_audit")
}

model JournalEntryTemplate {
  id          String                     @id @default(cuid())
  entityId    String
  name        String
  description String?
  createdBy   String
  isRecurring Boolean                    @default(false)
  frequency   String?                    // "monthly" | "quarterly" | "annually"
  nextRunDate DateTime?                  @db.Date
  lastRunDate DateTime?                  @db.Date
  createdAt   DateTime                   @default(now())
  updatedAt   DateTime                   @updatedAt
  entity           Entity                     @relation(fields: [entityId], references: [id])
  lines            JournalEntryTemplateLine[]
  generatedEntries JournalEntry[]

  @@unique([entityId, name])
  @@index([isRecurring, nextRunDate])
  @@map("journal_entry_templates")
}

model JournalEntryTemplateLine {
  id         String                 @id @default(cuid())
  templateId String
  accountId  String
  debit      Decimal                @default(0) @db.Decimal(19, 4)
  credit     Decimal                @default(0) @db.Decimal(19, 4)
  memo       String?
  sortOrder  Int                    @default(0)
  template   JournalEntryTemplate   @relation(fields: [templateId], references: [id], onDelete: Cascade)
  account    Account                @relation(fields: [accountId], references: [id])

  @@index([templateId])
  @@map("journal_entry_template_lines")
}

model SubledgerItem {
  id              String              @id @default(cuid())
  entityId        String
  accountId       String
  name            String              // "Chase Operating #4421", "Fund III - ABC Capital"
  itemType        SubledgerItemType
  // Financial
  costBasis       Decimal?            @db.Decimal(19, 4)
  fairMarketValue Decimal?            @db.Decimal(19, 4)
  currentBalance  Decimal             @default(0) @db.Decimal(19, 4)
  // Metadata
  counterparty    String?             // "Chase Bank", "ABC Capital Partners"
  referenceNumber String?             // account #, loan #, parcel #
  acquiredDate    DateTime?           @db.Date
  maturityDate    DateTime?           @db.Date
  interestRate    Decimal?            @db.Decimal(5, 4)
  notes           String?
  isActive        Boolean             @default(true)
  createdAt       DateTime            @default(now())
  updatedAt       DateTime            @updatedAt
  entity          Entity              @relation(fields: [entityId], references: [id])
  account         Account             @relation(fields: [accountId], references: [id])
  reconciliations BankReconciliation[]
  positions       Position[]

  @@index([entityId, accountId])
  @@index([entityId, itemType])
  @@map("subledger_items")
}

model Position {
  id              String          @id @default(cuid())
  subledgerItemId String
  name            String          // "AAPL", "Cash Sweep", "Land", "Building"
  positionType    PositionType
  // Quantities (for securities)
  quantity        Decimal?        @db.Decimal(19, 6)
  unitCost        Decimal?        @db.Decimal(19, 6)
  unitPrice       Decimal?        @db.Decimal(19, 6)
  // Values
  costBasis       Decimal?        @db.Decimal(19, 4)
  marketValue     Decimal         @default(0) @db.Decimal(19, 4)
  // Metadata
  ticker          String?
  assetClass      String?         // "Large Cap", "Fixed Income", "Cash", etc.
  acquiredDate    DateTime?       @db.Date
  notes           String?
  isActive        Boolean         @default(true)
  createdAt       DateTime        @default(now())
  updatedAt       DateTime        @updatedAt
  subledgerItem   SubledgerItem   @relation(fields: [subledgerItemId], references: [id], onDelete: Cascade)

  @@index([subledgerItemId])
  @@map("positions")
}

model BankReconciliation {
  id              String              @id @default(cuid())
  subledgerItemId String
  statementDate   DateTime            @db.Date
  statementBalance Decimal            @db.Decimal(19, 4)
  glBalance       Decimal             @db.Decimal(19, 4)
  difference      Decimal             @db.Decimal(19, 4)
  status          ReconciliationStatus @default(IN_PROGRESS)
  reconciledBy    String?
  reconciledAt    DateTime?
  notes           String?
  createdAt       DateTime            @default(now())
  updatedAt       DateTime            @updatedAt
  subledgerItem   SubledgerItem       @relation(fields: [subledgerItemId], references: [id])
  lines           BankReconciliationLine[]

  @@index([subledgerItemId])
  @@map("bank_reconciliations")
}

model BankReconciliationLine {
  id               String             @id @default(cuid())
  reconciliationId String
  // GL side (from journal entry lines)
  journalEntryLineId String?
  // Statement side (from uploaded bank statement)
  statementDate    DateTime?          @db.Date
  statementDesc    String?
  statementAmount  Decimal?           @db.Decimal(19, 4)
  statementRef     String?
  // Matching
  matchStatus      MatchStatus        @default(UNMATCHED)
  createdAt        DateTime           @default(now())
  reconciliation   BankReconciliation @relation(fields: [reconciliationId], references: [id], onDelete: Cascade)
  journalEntryLine JournalEntryLine?  @relation(fields: [journalEntryLineId], references: [id])

  @@index([reconciliationId])
  @@map("bank_reconciliation_lines")
}

model PeriodClose {
  id       String   @id @default(cuid())
  entityId String
  year     Int
  month    Int
  closedBy String
  closedAt DateTime @default(now())
  entity   Entity   @relation(fields: [entityId], references: [id])

  @@unique([entityId, year, month])
  @@map("period_closes")
}

enum EntityType {
  LP
  LLC
  CORPORATION
  S_CORP
  TRUST
  FOUNDATION
  PARTNERSHIP
  INDIVIDUAL
  OTHER
}

enum CoaTemplate {
  TEMPLATE
  BLANK
}

enum AccountType {
  ASSET
  LIABILITY
  EQUITY
  INCOME
  EXPENSE
}

enum JournalEntryStatus {
  DRAFT
  APPROVED
  POSTED
}

enum SubledgerItemType {
  BANK_ACCOUNT
  INVESTMENT
  REAL_ESTATE
  LOAN
  PRIVATE_EQUITY
  RECEIVABLE
  OTHER
}

enum ReconciliationStatus {
  IN_PROGRESS
  COMPLETED
}

enum MatchStatus {
  MATCHED
  UNMATCHED
}

enum PositionType {
  CASH
  PUBLIC_EQUITY
  FIXED_INCOME
  MUTUAL_FUND
  ETF
  PRIVATE_EQUITY
  REAL_PROPERTY
  ACCUMULATED_DEPRECIATION
  OTHER
}

model EntityAccess {
  id        String           @id @default(cuid())
  entityId  String
  userId    String
  role      EntityAccessRole @default(EDITOR)
  createdAt DateTime         @default(now())
  entity    Entity           @relation(fields: [entityId], references: [id], onDelete: Cascade)
  user      User             @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([entityId, userId])
  @@index([entityId])
  @@index([userId])
  @@map("entity_access")
}

model Attachment {
  id             String       @id @default(cuid())
  journalEntryId String
  fileName       String
  fileType       String       // MIME type: "image/png", "application/pdf", etc.
  fileSize       Int          // bytes
  url            String       // Vercel Blob URL
  uploadedBy     String
  createdAt      DateTime     @default(now())
  journalEntry   JournalEntry @relation(fields: [journalEntryId], references: [id], onDelete: Cascade)

  @@index([journalEntryId])
  @@map("attachments")
}

enum EntityAccessRole {
  OWNER
  EDITOR
  VIEWER
}
