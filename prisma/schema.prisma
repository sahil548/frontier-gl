// DI-01: All money/financial fields use Decimal(19,4) — @db.Decimal(19, 4)
// DI-02: All financial tables include entityId FK for entity-scoped data isolation

generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model User {
  id           String         @id @default(cuid())
  clerkId      String         @unique
  email        String         @unique
  name         String?
  createdAt    DateTime       @default(now())
  updatedAt    DateTime       @updatedAt
  entities     Entity[]
  entityAccess EntityAccess[]
}

model Entity {
  id             String         @id @default(cuid())
  name           String
  type           EntityType
  typeOther      String?
  fiscalYearEnd  String
  coaTemplate    CoaTemplate    @default(BLANK)
  isActive       Boolean        @default(true)
  createdById    String
  createdAt      DateTime       @default(now())
  updatedAt      DateTime       @updatedAt
  createdBy      User           @relation(fields: [createdById], references: [id])
  accounts       Account[]
  journalEntries JournalEntry[]
  periodCloses   PeriodClose[]
  templates      JournalEntryTemplate[]
  subledgerItems SubledgerItem[]
  access         EntityAccess[]
  dimensions     Dimension[]
  budgets        Budget[]
  eliminationRulesAsA  EliminationRule[]    @relation("EliminationRuleEntityA")
  eliminationRulesAsB  EliminationRule[]    @relation("EliminationRuleEntityB")
  categorizationRules  CategorizationRule[]

  @@index([createdById])
  @@index([isActive])
}

model Account {
  id          String             @id @default(cuid())
  entityId    String
  number      String
  name        String
  type        AccountType
  description String?
  parentId    String?
  isActive    Boolean            @default(true)
  createdAt   DateTime           @default(now())
  updatedAt   DateTime           @updatedAt
  balance     AccountBalance?
  entity      Entity             @relation(fields: [entityId], references: [id])
  parent      Account?           @relation("AccountHierarchy", fields: [parentId], references: [id])
  children    Account[]          @relation("AccountHierarchy")
  lineItems      JournalEntryLine[]
  templateLines  JournalEntryTemplateLine[]
  subledgerItems SubledgerItem[]
  budgets        Budget[]
  eliminationRulesAsA  EliminationRule[]    @relation("EliminationRuleAccountA")
  eliminationRulesAsB  EliminationRule[]    @relation("EliminationRuleAccountB")
  bankTransactions     BankTransaction[]
  categorizationRules  CategorizationRule[]
  positions            Position[]

  @@unique([entityId, number])
  @@index([entityId, isActive])
  @@index([entityId, type])
  @@map("accounts")
}

model AccountBalance {
  id          String   @id @default(cuid())
  accountId   String   @unique
  debitTotal  Decimal  @default(0) @db.Decimal(19, 4)
  creditTotal Decimal  @default(0) @db.Decimal(19, 4)
  balance     Decimal  @default(0) @db.Decimal(19, 4)
  updatedAt   DateTime @updatedAt
  account     Account  @relation(fields: [accountId], references: [id])

  @@map("account_balances")
}

model JournalEntry {
  id           String              @id @default(cuid())
  entityId     String
  entryNumber  String
  date         DateTime            @db.Date
  description  String
  status       JournalEntryStatus  @default(DRAFT)
  createdBy    String
  approvedBy   String?
  postedBy     String?
  createdAt    DateTime            @default(now())
  approvedAt   DateTime?
  postedAt     DateTime?
  updatedAt    DateTime            @updatedAt
  reversalOfId String?             @unique
  entity       Entity              @relation(fields: [entityId], references: [id])
  reversalOf   JournalEntry?       @relation("Reversal", fields: [reversalOfId], references: [id])
  reversedBy   JournalEntry?       @relation("Reversal")
  templateId   String?
  template     JournalEntryTemplate? @relation(fields: [templateId], references: [id])
  auditEntries    JournalEntryAudit[]
  lineItems       JournalEntryLine[]
  attachments     Attachment[]
  bankTransaction BankTransaction?

  @@unique([entityId, entryNumber])
  @@index([entityId, status])
  @@index([entityId, date])
  @@map("journal_entries")
}

model JournalEntryLine {
  id             String       @id @default(cuid())
  journalEntryId String
  accountId      String
  debit          Decimal      @default(0) @db.Decimal(19, 4)
  credit         Decimal      @default(0) @db.Decimal(19, 4)
  memo           String?
  sortOrder      Int          @default(0)
  account        Account      @relation(fields: [accountId], references: [id])
  journalEntry   JournalEntry @relation(fields: [journalEntryId], references: [id], onDelete: Cascade)
  reconciliationLines BankReconciliationLine[]
  dimensionTags       JournalEntryLineDimensionTag[]

  @@index([journalEntryId])
  @@index([accountId])
  @@map("journal_entry_lines")
}

model JournalEntryAudit {
  id             String       @id @default(cuid())
  journalEntryId String
  action         String
  userId         String
  changes        Json?
  createdAt      DateTime     @default(now())
  journalEntry   JournalEntry @relation(fields: [journalEntryId], references: [id])

  @@index([journalEntryId])
  @@map("journal_entry_audit")
}

model JournalEntryTemplate {
  id          String                     @id @default(cuid())
  entityId    String
  name        String
  description String?
  createdBy   String
  isRecurring Boolean                    @default(false)
  frequency   String?                    // "monthly" | "quarterly" | "annually"
  nextRunDate DateTime?                  @db.Date
  lastRunDate DateTime?                  @db.Date
  createdAt   DateTime                   @default(now())
  updatedAt   DateTime                   @updatedAt
  entity           Entity                     @relation(fields: [entityId], references: [id])
  lines            JournalEntryTemplateLine[]
  generatedEntries JournalEntry[]

  @@unique([entityId, name])
  @@index([isRecurring, nextRunDate])
  @@map("journal_entry_templates")
}

model JournalEntryTemplateLine {
  id         String                 @id @default(cuid())
  templateId String
  accountId  String
  debit      Decimal                @default(0) @db.Decimal(19, 4)
  credit     Decimal                @default(0) @db.Decimal(19, 4)
  memo       String?
  sortOrder  Int                    @default(0)
  template   JournalEntryTemplate   @relation(fields: [templateId], references: [id], onDelete: Cascade)
  account    Account                @relation(fields: [accountId], references: [id])

  @@index([templateId])
  @@map("journal_entry_template_lines")
}

model SubledgerItem {
  id              String              @id @default(cuid())
  entityId        String
  accountId       String
  name            String              // "Chase Operating #4421", "Fund III - ABC Capital"
  itemType        SubledgerItemType
  // Financial
  costBasis       Decimal?            @db.Decimal(19, 4)
  fairMarketValue Decimal?            @db.Decimal(19, 4)
  currentBalance  Decimal             @default(0) @db.Decimal(19, 4)
  // Metadata
  counterparty    String?             // "Chase Bank", "ABC Capital Partners"
  referenceNumber String?             // account #, loan #, parcel #
  acquiredDate    DateTime?           @db.Date
  maturityDate    DateTime?           @db.Date
  interestRate    Decimal?            @db.Decimal(5, 4)
  notes           String?
  isActive        Boolean             @default(true)
  createdAt       DateTime            @default(now())
  updatedAt       DateTime            @updatedAt
  entity          Entity              @relation(fields: [entityId], references: [id])
  account         Account             @relation(fields: [accountId], references: [id])
  reconciliations  BankReconciliation[]
  positions        Position[]
  bankTransactions BankTransaction[]
  plaidConnection  PlaidConnection?

  @@index([entityId, accountId])
  @@index([entityId, itemType])
  @@map("subledger_items")
}

model Position {
  id              String          @id @default(cuid())
  subledgerItemId String
  accountId       String?         // GL anchor for position (nullable for migration compatibility)
  name            String          // "AAPL", "Cash Sweep", "Land", "Building"
  positionType    PositionType
  // Quantities (for securities)
  quantity        Decimal?        @db.Decimal(19, 6)
  unitCost        Decimal?        @db.Decimal(19, 6)
  unitPrice       Decimal?        @db.Decimal(19, 6)
  // Values
  costBasis       Decimal?        @db.Decimal(19, 4)
  marketValue     Decimal         @default(0) @db.Decimal(19, 4)
  // Metadata
  ticker          String?
  assetClass      String?         // "Large Cap", "Fixed Income", "Cash", etc.
  acquiredDate    DateTime?       @db.Date
  notes           String?
  isActive        Boolean         @default(true)
  createdAt       DateTime        @default(now())
  updatedAt       DateTime        @updatedAt
  subledgerItem   SubledgerItem   @relation(fields: [subledgerItemId], references: [id], onDelete: Cascade)
  account         Account?        @relation(fields: [accountId], references: [id])
  categorizationRules CategorizationRule[]
  bankTransactions    BankTransaction[]

  @@index([subledgerItemId])
  @@index([accountId])
  @@map("positions")
}

model BankReconciliation {
  id              String              @id @default(cuid())
  subledgerItemId String
  statementDate   DateTime            @db.Date
  statementBalance Decimal            @db.Decimal(19, 4)
  glBalance       Decimal             @db.Decimal(19, 4)
  difference      Decimal             @db.Decimal(19, 4)
  status          ReconciliationStatus @default(IN_PROGRESS)
  reconciledBy    String?
  reconciledAt    DateTime?
  notes           String?
  createdAt       DateTime            @default(now())
  updatedAt       DateTime            @updatedAt
  subledgerItem   SubledgerItem       @relation(fields: [subledgerItemId], references: [id])
  lines           BankReconciliationLine[]

  @@index([subledgerItemId])
  @@map("bank_reconciliations")
}

model BankReconciliationLine {
  id               String             @id @default(cuid())
  reconciliationId String
  // GL side (from journal entry lines)
  journalEntryLineId String?
  // Statement side (from uploaded bank statement)
  statementDate    DateTime?          @db.Date
  statementDesc    String?
  statementAmount  Decimal?           @db.Decimal(19, 4)
  statementRef     String?
  // Matching
  matchStatus      MatchStatus        @default(UNMATCHED)
  createdAt        DateTime           @default(now())
  reconciliation   BankReconciliation @relation(fields: [reconciliationId], references: [id], onDelete: Cascade)
  journalEntryLine JournalEntryLine?  @relation(fields: [journalEntryLineId], references: [id])

  @@index([reconciliationId])
  @@map("bank_reconciliation_lines")
}

model PeriodClose {
  id       String   @id @default(cuid())
  entityId String
  year     Int
  month    Int
  closedBy String
  closedAt DateTime @default(now())
  entity   Entity   @relation(fields: [entityId], references: [id])

  @@unique([entityId, year, month])
  @@map("period_closes")
}

model Dimension {
  id        String         @id @default(cuid())
  entityId  String
  name      String
  sortOrder Int            @default(0)
  isActive  Boolean        @default(true)
  createdAt DateTime       @default(now())
  updatedAt DateTime       @updatedAt
  entity    Entity         @relation(fields: [entityId], references: [id])
  tags      DimensionTag[]

  @@unique([entityId, name])
  @@index([entityId, isActive])
  @@map("dimensions")
}

model DimensionTag {
  id              String                        @id @default(cuid())
  dimensionId     String
  code            String
  name            String
  description     String?
  isActive        Boolean                       @default(true)
  sortOrder       Int                           @default(0)
  createdAt       DateTime                      @default(now())
  updatedAt       DateTime                      @updatedAt
  dimension       Dimension                     @relation(fields: [dimensionId], references: [id], onDelete: Cascade)
  lineAssignments JournalEntryLineDimensionTag[]

  @@unique([dimensionId, code])
  @@unique([dimensionId, name])
  @@index([dimensionId, isActive])
  @@map("dimension_tags")
}

model JournalEntryLineDimensionTag {
  id                 String           @id @default(cuid())
  journalEntryLineId String
  dimensionTagId     String
  journalEntryLine   JournalEntryLine @relation(fields: [journalEntryLineId], references: [id], onDelete: Cascade)
  dimensionTag       DimensionTag     @relation(fields: [dimensionTagId], references: [id])

  @@unique([journalEntryLineId, dimensionTagId])
  @@index([journalEntryLineId])
  @@index([dimensionTagId])
  @@map("journal_entry_line_dimension_tags")
}

model Budget {
  id        String   @id @default(cuid())
  entityId  String
  accountId String
  year      Int
  month     Int
  amount    Decimal  @default(0) @db.Decimal(19, 4)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  entity    Entity   @relation(fields: [entityId], references: [id])
  account   Account  @relation(fields: [accountId], references: [id])

  @@unique([entityId, accountId, year, month])
  @@index([entityId, year])
  @@map("budgets")
}

model EliminationRule {
  id         String   @id @default(cuid())
  label      String
  entityAId  String
  accountAId String
  entityBId  String
  accountBId String
  isActive   Boolean  @default(true)
  createdBy  String
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt
  entityA    Entity   @relation("EliminationRuleEntityA", fields: [entityAId], references: [id])
  accountA   Account  @relation("EliminationRuleAccountA", fields: [accountAId], references: [id])
  entityB    Entity   @relation("EliminationRuleEntityB", fields: [entityBId], references: [id])
  accountB   Account  @relation("EliminationRuleAccountB", fields: [accountBId], references: [id])

  @@index([entityAId])
  @@index([entityBId])
  @@index([isActive])
  @@map("elimination_rules")
}

enum EntityType {
  LP
  LLC
  CORPORATION
  S_CORP
  TRUST
  FOUNDATION
  PARTNERSHIP
  INDIVIDUAL
  OTHER
}

enum CoaTemplate {
  TEMPLATE
  BLANK
}

enum AccountType {
  ASSET
  LIABILITY
  EQUITY
  INCOME
  EXPENSE
}

enum JournalEntryStatus {
  DRAFT
  APPROVED
  POSTED
}

enum SubledgerItemType {
  // New canonical types (13)
  BANK_ACCOUNT
  BROKERAGE_ACCOUNT
  CREDIT_CARD
  REAL_ESTATE
  EQUIPMENT
  LOAN
  PRIVATE_FUND
  MORTGAGE
  LINE_OF_CREDIT
  TRUST_ACCOUNT
  OPERATING_BUSINESS
  NOTES_RECEIVABLE
  OTHER
  // Legacy types (kept for data compatibility)
  INVESTMENT
  PRIVATE_EQUITY
  RECEIVABLE
}

enum ReconciliationStatus {
  IN_PROGRESS
  COMPLETED
}

enum MatchStatus {
  MATCHED
  UNMATCHED
}

enum PositionType {
  CASH
  PUBLIC_EQUITY
  FIXED_INCOME
  MUTUAL_FUND
  ETF
  PRIVATE_EQUITY
  REAL_PROPERTY
  ACCUMULATED_DEPRECIATION
  OTHER
}

model EntityAccess {
  id        String           @id @default(cuid())
  entityId  String
  userId    String
  role      EntityAccessRole @default(EDITOR)
  createdAt DateTime         @default(now())
  entity    Entity           @relation(fields: [entityId], references: [id], onDelete: Cascade)
  user      User             @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([entityId, userId])
  @@index([entityId])
  @@index([userId])
  @@map("entity_access")
}

model Attachment {
  id             String       @id @default(cuid())
  journalEntryId String
  fileName       String
  fileType       String       // MIME type: "image/png", "application/pdf", etc.
  fileSize       Int          // bytes
  url            String       // Vercel Blob URL
  uploadedBy     String
  createdAt      DateTime     @default(now())
  journalEntry   JournalEntry @relation(fields: [journalEntryId], references: [id], onDelete: Cascade)

  @@index([journalEntryId])
  @@map("attachments")
}

enum EntityAccessRole {
  OWNER
  EDITOR
  VIEWER
}

enum TransactionSource {
  CSV
  PLAID
}

enum TransactionStatus {
  PENDING
  CATEGORIZED
  POSTED
  EXCLUDED
}

enum PlaidConnectionStatus {
  ACTIVE
  ERROR
  DISCONNECTED
}

model BankTransaction {
  id                    String            @id @default(cuid())
  subledgerItemId       String
  externalId            String?
  date                  DateTime          @db.Date
  description           String
  amount                Decimal           @db.Decimal(19, 4)
  originalDescription   String?
  merchantName          String?
  category              String?
  source                TransactionSource
  status                TransactionStatus @default(PENDING)
  accountId             String?
  positionId            String?
  reconciliationStatus  String            @default("PENDING")
  ruleId                String?
  isSplit               Boolean           @default(false)
  parentTransactionId   String?
  journalEntryId        String?           @unique
  createdAt             DateTime          @default(now())
  updatedAt             DateTime          @updatedAt
  subledgerItem         SubledgerItem     @relation(fields: [subledgerItemId], references: [id])
  account               Account?          @relation(fields: [accountId], references: [id])
  position              Position?         @relation(fields: [positionId], references: [id])
  rule                  CategorizationRule? @relation(fields: [ruleId], references: [id])
  journalEntry          JournalEntry?     @relation(fields: [journalEntryId], references: [id])
  parentTransaction     BankTransaction?  @relation("TransactionSplit", fields: [parentTransactionId], references: [id])
  childTransactions     BankTransaction[] @relation("TransactionSplit")

  @@unique([subledgerItemId, externalId])
  @@index([subledgerItemId, status])
  @@index([subledgerItemId, date])
  @@map("bank_transactions")
}

model PlaidConnection {
  id              String                @id @default(cuid())
  subledgerItemId String                @unique
  accessToken     String
  itemId          String
  institutionId   String?
  institutionName String?
  plaidAccountId  String?
  syncCursor      String?
  lastSyncAt      DateTime?
  status          PlaidConnectionStatus @default(ACTIVE)
  error           String?
  createdAt       DateTime              @default(now())
  updatedAt       DateTime              @updatedAt
  subledgerItem   SubledgerItem         @relation(fields: [subledgerItemId], references: [id])

  @@index([status])
  @@map("plaid_connections")
}

model CategorizationRule {
  id              String            @id @default(cuid())
  entityId        String
  pattern         String
  amountMin       Decimal?          @db.Decimal(19, 4)
  amountMax       Decimal?          @db.Decimal(19, 4)
  accountId       String?
  positionId      String?
  dimensionTags   Json?
  isActive        Boolean           @default(true)
  priority        Int               @default(0)
  createdAt       DateTime          @default(now())
  updatedAt       DateTime          @updatedAt
  entity          Entity            @relation(fields: [entityId], references: [id])
  account         Account?          @relation(fields: [accountId], references: [id])
  position        Position?         @relation(fields: [positionId], references: [id])
  bankTransactions BankTransaction[]

  @@index([entityId, isActive])
  @@map("categorization_rules")
}
